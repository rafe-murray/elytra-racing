{
	"schemaVersion": 1,
	"id": "elytra-racing",
	"version": "${version}",
	"name": "Elytra Racing",
	"description": "Grab your elytra and race with your friends!",
	"authors": [
		"Rafe Murray"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/elytra-racing/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
          "ca.rafemurray.ElytraRacing"
		],
		"client": [
			"ca.rafemurray.client.ElytraRacingClient"
		]
	},
	"mixins": [
		"elytra-racing.mixins.json",
		{
			"config": "elytra-racing.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}