    },
    {
      "apply": { "model": "elytra-racing:block/booster_north", "y": 180 },
      "when": { "AND": [ {"south": "false"}, {"facing": "up"}]}
    },
    {
      "apply": { "model": "elytra-racing:block/booster_north", "y": 270 },
      "when": { "AND": [ {"west": "false"}, {"facing": "up"}]}
    },
    {
      "apply": { "model": "elytra-racing:block/booster_connected_north" },
